    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Walking person</uri>
      <name>firefighter2</name>
      <pose>32 -46 0 0 0 0.5</pose>
    </include>

    <!-- 受伤平民 (废墟边缘, 坐姿) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Rescue Randy Sitting</uri>
      <name>injured_civilian</name>
      <pose>38 -26 0 0 0 2.0</pose>
    </include>

  </world>
</sdf>
