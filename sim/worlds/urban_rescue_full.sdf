    <!-- ═══════════════════════════════════════════════════════════
         F区 — 火灾区域 (C区废墟西侧)
         Gazebo: X=35, Y=-45  →  NED: (-45, 35)
         ═══════════════════════════════════════════════════════════ -->

    <!-- 着火建筑: 主体 + 火焰 + 烟柱 -->
    <model name="fire_building">
      <static>true</static>
      <pose>35 -45 0 0 0 0.2</pose>
      <link name="body">
        <!-- 建筑主体 (深色, 烧焦感) -->
        <visual name="building_base">
          <pose>0 0 2.5 0 0 0</pose>
          <geometry><box><size>8 6 5</size></box></geometry>
          <material>
            <ambient>0.15 0.1 0.08 1</ambient>
            <diffuse>0.25 0.18 0.12 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
        <!-- 坍塌的屋顶 (倾斜) -->
        <visual name="collapsed_roof">
          <pose>-1 0 5.5 0.2 0.15 0</pose>
          <geometry><box><size>6 5 0.3</size></box></geometry>
          <material>
            <ambient>0.2 0.15 0.1 1</ambient>
            <diffuse>0.3 0.22 0.15 1</diffuse>
          </material>
        </visual>
        <!-- 火焰1: 大火 (鲜橙红, 发光) -->
        <visual name="flames_main">
          <pose>1.5 0 5.5 0 0 0</pose>
          <geometry><cylinder><radius>1.2</radius><length>3.5</length></cylinder></geometry>
          <material>
            <ambient>1.0 0.35 0.0 1</ambient>
            <diffuse>1.0 0.45 0.05 1</diffuse>
            <emissive>1.0 0.3 0.0 1</emissive>
          </material>
        </visual>
        <!-- 火焰2: 侧面小火 -->
        <visual name="flames_side">
          <pose>-2 1.5 4.0 0 0.1 0</pose>
          <geometry><cylinder><radius>0.7</radius><length>2.0</length></cylinder></geometry>
          <material>
            <ambient>1.0 0.5 0.0 1</ambient>
            <diffuse>1.0 0.6 0.1 1</diffuse>
            <emissive>0.9 0.4 0.0 1</emissive>
          </material>
        </visual>
        <!-- 烟柱: 深灰/黑色 -->
        <visual name="smoke_column">
          <pose>1.0 0 9 0 0 0</pose>
          <geometry><cylinder><radius>2.5</radius><length>8</length></cylinder></geometry>
          <material>
            <ambient>0.12 0.12 0.12 0.7</ambient>
            <diffuse>0.2 0.2 0.2 0.6</diffuse>
          </material>
        </visual>
        <!-- 烟柱顶部: 更宽更淡 -->
        <visual name="smoke_top">
          <pose>0.5 0.5 14 0 0 0</pose>
          <geometry><cylinder><radius>4.0</radius><length>4</length></cylinder></geometry>
          <material>
            <ambient>0.15 0.15 0.15 0.4</ambient>
            <diffuse>0.25 0.25 0.25 0.3</diffuse>
          </material>
        </visual>
        <collision name="c">
          <pose>0 0 2.5 0 0 0</pose>
          <geometry><box><size>8 6 5</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- 火灾蔓延的地面焦痕 -->
    <model name="fire_ground">
      <static>true</static>
      <pose>35 -45 0.02 0 0 0</pose>
      <link name="l">
        <visual name="v">
          <geometry><box><size>14 12 0.01</size></box></geometry>
          <material>
            <ambient>0.08 0.06 0.04 1</ambient>
            <diffuse>0.12 0.08 0.05 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- 火灾旁的消防车 (Fuel 模型) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Fire truck</uri>
      <name>fire_truck</name>
      <pose>28 -50 0 0 0 0.8</pose>
    </include>

    <!-- ═══════════════════════════════════════════════════════════
         G区 — 求救信号 / 标记物 (废墟区内)
         ═══════════════════════════════════════════════════════════ -->

    <!-- 红色求救布 (大块红色方块, 铺在地面, 高对比度) -->
    <model name="sos_signal">
      <static>true</static>
      <pose>45 -33 0.05 0 0 0.3</pose>
      <link name="l">
        <visual name="v">
          <geometry><box><size>4 4 0.05</size></box></geometry>
          <material>
            <ambient>0.95 0.05 0.05 1</ambient>
            <diffuse>1.0 0.1 0.1 1</diffuse>
            <emissive>0.5 0.0 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- SOS 字母标志 (白色竖板) -->
    <model name="sos_sign">
      <static>true</static>
      <pose>45 -33 1.5 0 0 0.3</pose>
      <link name="l">
        <visual name="v">
          <geometry><box><size>2.5 0.1 1.5</size></box></geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>1.0 1.0 1.0 1</diffuse>
            <emissive>0.3 0.3 0.3 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════
         场景增强 — 路障 / 锥桶 / 警戒带
         ═══════════════════════════════════════════════════════════ -->

    <!-- 路障 (Jersey Barriers, 封锁废墟区入口) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Jersey Barrier</uri>
      <name>barrier1</name>
      <pose>30 -20 0 0 0 0.5</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Jersey Barrier</uri>
      <name>barrier2</name>
      <pose>32 -22 0 0 0 0.5</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Jersey Barrier</uri>
      <name>barrier3</name>
      <pose>34 -24 0 0 0 0.5</pose>
    </include>

    <!-- 交通锥 (Construction Cones, 标记危险区域边界) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Cone</uri>
      <name>cone1</name>
      <pose>38 -20 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Cone</uri>
      <name>cone2</name>
      <pose>55 -18 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Cone</uri>
      <name>cone3</name>
      <pose>68 -28 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Cone</uri>
      <name>cone4</name>
      <pose>65 -55 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Cone</uri>
      <name>cone5</name>
      <pose>38 -55 0 0 0 0</pose>
    </include>

    <!-- 施工桶 (警示) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Barrel</uri>
      <name>barrel1</name>
      <pose>42 -22 0 0 0 0</pose>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Construction Barrel</uri>
      <name>barrel2</name>
      <pose>62 -25 0 0 0 0</pose>
    </include>

    <!-- 翻倒的垃圾箱 (灾后场景感) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Dumpster</uri>
      <name>dumpster1</name>
      <pose>48 -28 0 0 0.3 0.8</pose>
    </include>

    <!-- ═══════════════════════════════════════════════════════════
         场景增强 — 更多车辆
         ═══════════════════════════════════════════════════════════ -->

    <!-- 警示锥桶 (代替警车，标记入口) -->
    <model name="police_marker">
      <static>true</static>
      <pose>25 -18 0 0 0 0</pose>
      <link name="l">
        <visual name="base">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry><box><size>2 1 1</size></box></geometry>
          <material>
            <ambient>0.1 0.1 0.5 1</ambient>
            <diffuse>0.15 0.15 0.7 1</diffuse>
          </material>
        </visual>
        <visual name="light">
          <pose>0 0 1.2 0 0 0</pose>
          <geometry><cylinder><radius>0.3</radius><length>0.4</length></cylinder></geometry>
          <material>
            <ambient>0.0 0.2 0.9 1</ambient>
            <diffuse>0.1 0.3 1.0 1</diffuse>
            <emissive>0.0 0.2 1.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- SUV (被困在废墟边缘) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/SUV</uri>
      <name>suv_trapped</name>
      <pose>52 -28 0 0 0.05 1.2</pose>
    </include>

    <!-- ═══════════════════════════════════════════════════════════
         场景增强 — 更多人员
         ═══════════════════════════════════════════════════════════ -->

    <!-- 消防员 (火灾附近) -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Standing person</uri>
      <name>firefighter1</name>
      <pose>30 -48 0 0 0 1.0</pose>
